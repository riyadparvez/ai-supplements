{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "LSP",
      "Edit",
      "MultiEdit",
      "WebFetch(domain:gunicorn.org)",
      "WebFetch(domain:*.weather.gc.ca)",
      "WebSearch",
      "mcp__serena__find_symbol",
      "mcp__serena__get_symbols_overview",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Read(//temp/readonly/**)",
      "Read(//private/var/folders/**)",
      "Bash(.venv/bin/pip show *)",
      "Bash(awk '-F ' '{print $NF}')",
      "Bash(awk -F. '{print $\\(NF-1\\) \".\" $NF}')",
      "Bash(awk '{print $\\(NF-2\\) \" \" $\\(NF-1\\) \" \" $NF}')",
      "Bash(cat *)",
      "Bash(cd /Users/riyad/dev-src/*)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(git blame *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(pipenv lock *)",
      "Bash(python -c ' *)",
      "Bash(python -m pytest tests/test_soil_sync.py -k \"test_sync_readings_batch\" -v)",
      "Bash(.venv/bin/python -m pytest *)",
      "Bash(sed *)",
      "Bash(sort -t'.' -k1 -nr)",
      "Bash(tail *)",
      "Bash(uv pip:*)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(xargs ls *)",
      "Bash(xargs -I {} basename {})",
      "Read(//Users/riyad/.claude/plans/**)",
      "Read(//Users/riyad/dev-src/**)"
    ],
    "deny": [
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(curl * | sh)",
      "Bash(git push --force*)",
      "Bash(git push origin master)",
      "Bash(rm -rf *)",
      "Bash(ssh:*)",
      "Bash(sudo *)",
      "Bash(wget * | sh)"
    ],
    "additionalDirectories": [
      "/Users/riyad/dev-src/pipeline/pipeline/src/pipeline",
      "/tmp",
      "/Users/riyad/dev-src/pipeline/device_ingestion/src/device_ingestion",
      "/Users/riyad/dev-src/pipeline/plugfield_client/src/plugfield_client"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
          },
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path'); [[ \"$file\" == *.py ]] && uv run black \"$file\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pg@aiguide": false,
    "deploy-on-aws@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "gitlab@claude-plugins-official": true,
    "terraform@claude-plugins-official": false,
    "chrome-devtools-mcp@chrome-devtools-plugins": false,
    "claude-hud@claude-hud": true,
    "claude-mem@thedotmack": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "effortLevel": "medium",
  "network": {
    "allowedDomains": [
      "*.weather.gc.ca"
    ]
  },
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1"
  },
  "switchModelsOnFlag": false,
  "model": "sonnet"
}
